# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX        # Test key from Razorpay dashboard
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXX # Test secret from Razorpay dashboard

# ── Shiprocket ────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-password

# ── Supabase (optional — leave blank for local localStorage-only dev) ─────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# ── WhatsApp Bridge ───────────────────────────────────────────────────────────
WHATSAPP_BRIDGE_DIR=                          # e.g. /Users/you/whatsapp-bridge
WHATSAPP_DEVICE_DB=                           # e.g. /Users/you/whatsapp-bridge/store/whatsapp.db
WHATSAPP_DB_PATH=                             # e.g. /Users/you/whatsapp-bridge/messages.db
WHATSAPP_BRIDGE_API=http://localhost:8080     # WhatsApp Go bridge URL

# ── D2C Flow State ────────────────────────────────────────────────────────────
D2CFLOW_STORE_DIR=~/.d2cflow                  # Where WA orders/broadcasts are persisted

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
