FOUNDER_WHATSAPP=919876543210
FOUNDER_EMAIL=founder@yourbrand.in
LOW_STOCK_THRESHOLD=10
RTD_HOURS_THRESHOLD=24
COD_CONFIRM_TIMEOUT_HOURS=2

# ── Shopify ───────────────────────────────────────────────────────────────────
