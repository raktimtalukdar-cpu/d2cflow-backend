SHOPIFY_CLIENT_SECRET=
SHOPIFY_STORE_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# ── Amazon SP-API ─────────────────────────────────────────────────────────────
AMAZON_APP_ID=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV

# ── Flipkart ──────────────────────────────────────────────────────────────────
FLIPKART_CLIENT_ID=
FLIPKART_CLIENT_SECRET=

# ── Meesho ────────────────────────────────────────────────────────────────────
MEESHO_API_TOKEN=

# ── Myntra ────────────────────────────────────────────────────────────────────
MYNTRA_SUPPLIER_ID=
MYNTRA_API_KEY=

# ── Ajio ──────────────────────────────────────────────────────────────────────
AJIO_API_KEY=
AJIO_SELLER_ID=

# ── Nykaa ─────────────────────────────────────────────────────────────────────
NYKAA_API_TOKEN=
NYKAA_SELLER_ID=

# ── Snapdeal ──────────────────────────────────────────────────────────────────
SNAPDEAL_API_TOKEN=
SNAPDEAL_SELLER_ID=

# ── FirstCry ──────────────────────────────────────────────────────────────────
FIRSTCRY_API_TOKEN=
FIRSTCRY_SELLER_CODE=

# ── Shiprocket ────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-password

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret from Razorpay Dashboard → Webhooks → Add Webhook Secret
RAZORPAY_WEBHOOK_SECRET=

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── MoEngage Transactional Email ─────────────────────────────────────────────
# App ID + API Key from MoEngage Dashboard → Settings → APIs
MOENGAGE_APP_ID=
MOENGAGE_API_KEY=
MOENGAGE_SENDER_EMAIL=noreply@yourbrand.in
MOENGAGE_SENDER_NAME=D2C Flow
# API host by region: US=api-01, India=api-02, EU=api-03, Indonesia=api-04
MOENGAGE_API_HOST=api-02.moengage.com

# ── WhatsApp Bridge (local dev) ───────────────────────────────────────────────
WHATSAPP_BRIDGE_DIR=                          # e.g. /Users/you/whatsapp-bridge
WHATSAPP_DEVICE_DB=                           # e.g. /Users/you/whatsapp-bridge/store/whatsapp.db
WHATSAPP_DB_PATH=                             # e.g. /Users/you/whatsapp-bridge/messages.db
WHATSAPP_BRIDGE_API=http://localhost:8080

# ── D2C Flow State ────────────────────────────────────────────────────────────
D2CFLOW_STORE_DIR=~/.d2cflow

# ── Zoho Books ────────────────────────────────────────────────────────────────
# Generate access token: https://accounts.zoho.in/developerconsole
ZOHO_ACCESS_TOKEN=
ZOHO_ORGANIZATION_ID=

# ── Tally (via TallyConnector) ────────────────────────────────────────────────
# Install TallyConnector on the machine running Tally: https://tallyconnector.com
TALLY_HOST=http://localhost:9000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
